# =============================================================================
# THEDAL APPLICATION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/thedal
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=thedal_db

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRATION=30
JWT_REFRESH_TOKEN_EXPIRATION=60

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# SMTP Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# SendGrid Configuration
SENDGRID_KEY=your_sendgrid_api_key
SENDGRID_EMAIL=your_sendgrid_email@example.com
NOTIFICATION_EMAIL_RECIPIENT=notifications@example.com

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
# AWS S3 Configuration
AWS_S3_ACCESS_KEY=your_aws_s3_access_key
AWS_S3_SECRET_KEY=your_aws_s3_secret_key
AWS_S3_ENDPOINT=your_bucket.s3.region.amazonaws.com
AWS_S3_REGION=ap-south-1
AWS_S3_IMAGE_BUCKET=your_bucket/image
AWS_S3_NOTIFICATION_BUCKET=your_bucket/notification
AWS_S3_NOTIFICATION_FOLDER=templates/notifications
AWS_S3_BANNER_BUCKET=your_bucket/image/banner
AWS_S3_FILES_BUCKET=your_bucket/files
AWS_S3_CADRE_BUCKET=your_bucket/image/cadre

# AWS General Configuration
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_SQS_QUEUE_URL=https://sqs.region.amazonaws.com/account/queue_name

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================================================
# Cashfree Configuration
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_PUBLIC_KEY_PATH=classpath:accountId_1240656_public_key.pem
CASHFREE_OTP_URL=https://sandbox.cashfree.com/verification/offline-aadhaar/otp
CASHFREE_VERIFY_URL=https://sandbox.cashfree.com/verification/offline-aadhaar/verify

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password
REDIS_SSL=false

# =============================================================================
# SMS CONFIGURATION
# =============================================================================
# MSG91 Configuration
MSG91_AUTHKEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================
# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# =============================================================================
# APPLICATION URLS
# =============================================================================
THEDAL_DOMAIN_NAME=localhost
THEDAL_UI_URL=http://localhost:3000/
THEDAL_SERVER_URL=http://localhost:8080/

# =============================================================================
# PYTHON OCR SERVICE CONFIGURATION
# =============================================================================
PYTHON_OCR_SERVICE_URL=http://localhost:8000
PYTHON_OCR_SERVICE_TIMEOUT=300000
PYTHON_OCR_SERVICE_MAX_RETRIES=3
PYTHON_OCR_SERVICE_RETRY_DELAY=5000

# =============================================================================
# PRODUCTION EXAMPLE VALUES
# =============================================================================
# For production deployment, use values like:
# DB_URL=jdbc:postgresql://your-production-db:5432/thedal?sslmode=require
# MONGODB_URI=mongodb://username:password@production-mongo:27017/?authSource=admin
# THEDAL_UI_URL=https://your-production-domain.com/
# THEDAL_SERVER_URL=https://api.your-production-domain.com/
# REDIS_HOST=your-production-redis-host
# REDIS_SSL=true
