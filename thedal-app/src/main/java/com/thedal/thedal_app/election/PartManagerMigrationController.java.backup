package com.thedal.thedal_app.election;

import java.util.HashMap;
import java.util.Map;
import java.util.UUID;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.thedal.thedal_app.general.RequestDetailsService;
import com.thedal.thedal_app.response.ThedalResponse;
import com.thedal.thedal_app.response.ThedalSuccess;
import com.thedal.thedal_app.thedal_exception.ThedalError;
import com.thedal.thedal_app.thedal_exception.ThedalException;
import com.thedal.thedal_app.migration.MigrationJob;

import io.swagger.v3.oas.annotations.Operation;
import lombok.extern.slf4j.Slf4j;

@RestController
@RequestMapping("/api/part-managers/mongo")
@Slf4j
public class PartManagerMigrationController {

    @Autowired
    private PartManagerMigrationService partManagerMigrationService;
    
    @Autowired
    private RequestDetailsService requestDetails;

    @PostMapping("/election/{electionId}/migrate")
    @Operation(summary = "Initiate PartManager migration from PostgreSQL to MongoDB")
    public ThedalResponse<Map<String, Object>> initiatePartManagerMigration(@PathVariable("electionId") Long electionId) {
        
        // Validate account access
        Long accountId = requestDetails.getCurrentAccountId();
        if (accountId == null) {
            log.error("Account id not found, unauthorized access.");
            throw new ThedalException(ThedalError.ACCOUNT_ID_NOT_CREATED, HttpStatus.UNAUTHORIZED);
        }

        log.info("Initiating PartManager migration for accountId={}, electionId={}", accountId, electionId);

        try {
            // Generate unique job ID
            String jobId = UUID.randomUUID().toString();
            
            // Start async migration
            partManagerMigrationService.migratePartManagersAsync(accountId, electionId, jobId);
            
            Map<String, Object> response = new HashMap<>();
            response.put("jobId", jobId);
            response.put("message", "PartManager migration initiated successfully");
            response.put("accountId", accountId);
            response.put("electionId", electionId);
            
            return new ThedalResponse<>(ThedalSuccess.DATA_MIGRATION_INITIATED, response);
            
        } catch (Exception e) {
            log.error("Failed to initiate PartManager migration: {}", e.getMessage(), e);
            throw new ThedalException(ThedalError.OPERATION_FAILED, HttpStatus.INTERNAL_SERVER_ERROR);
        }
    }

    @GetMapping("/election/{electionId}/migration-status/{jobId}")
    @Operation(summary = "Get PartManager migration status")
    public ThedalResponse<Map<String, Object>> getPartManagerMigrationStatus(
            @PathVariable("electionId") Long electionId,
            @PathVariable("jobId") String jobId) {
        
        // Validate account access
        Long accountId = requestDetails.getCurrentAccountId();
        if (accountId == null) {
            log.error("Account id not found, unauthorized access.");
            throw new ThedalException(ThedalError.ACCOUNT_ID_NOT_CREATED, HttpStatus.UNAUTHORIZED);
        }

        log.debug("Getting PartManager migration status for jobId={}", jobId);

        try {
            MigrationJob job = partManagerMigrationService.getMigrationJob(jobId);
            
            if (job == null) {
                throw new ThedalException(ThedalError.MIGRATION_JOB_NOT_FOUND, HttpStatus.NOT_FOUND);
            }

            // Verify job belongs to the correct account and election
            if (!job.getAccountId().equals(accountId) || !job.getElectionId().equals(electionId)) {
                throw new ThedalException(ThedalError.UNAUTHORIZED_ACCESS, HttpStatus.FORBIDDEN);
            }

            Map<String, Object> response = new HashMap<>();
            response.put("jobId", job.getJobId());
            response.put("status", job.getStatus());
            response.put("totalRecords", job.getTotalRecords());
            response.put("migratedRecords", job.getMigratedRecords());
            response.put("progressPercentage", job.getProgressPercentage());
            response.put("startTime", job.getStartTime());
            response.put("endTime", job.getEndTime());
            response.put("duration", job.getDuration());
            
            if (job.getErrorMessage() != null) {
                response.put("errorMessage", job.getErrorMessage());
            }
            
            return new ThedalResponse<>(ThedalSuccess.SUCCESS, response);
            
        } catch (ThedalException e) {
            throw e;
        } catch (Exception e) {
            log.error("Failed to get PartManager migration status: {}", e.getMessage(), e);
            throw new ThedalException(ThedalError.OPERATION_FAILED, HttpStatus.INTERNAL_SERVER_ERROR);
        }
    }

    @PostMapping("/election/{electionId}/migration-cancel/{jobId}")
    @Operation(summary = "Cancel PartManager migration")
    public ThedalResponse<Map<String, String>> cancelPartManagerMigration(
            @PathVariable("electionId") Long electionId,
            @PathVariable("jobId") String jobId) {
        
        // Validate account access
        Long accountId = requestDetails.getCurrentAccountId();
        if (accountId == null) {
            log.error("Account id not found, unauthorized access.");
            throw new ThedalException(ThedalError.ACCOUNT_ID_NOT_CREATED, HttpStatus.UNAUTHORIZED);
        }

        log.info("Cancelling PartManager migration for jobId={}", jobId);

        try {
            MigrationJob job = partManagerMigrationService.getMigrationJob(jobId);
            
            if (job == null) {
                throw new ThedalException(ThedalError.MIGRATION_JOB_NOT_FOUND, HttpStatus.NOT_FOUND);
            }

            // Verify job belongs to the correct account and election
            if (!job.getAccountId().equals(accountId) || !job.getElectionId().equals(electionId)) {
                throw new ThedalException(ThedalError.UNAUTHORIZED_ACCESS, HttpStatus.FORBIDDEN);
            }

            partManagerMigrationService.cancelMigration(jobId);
            
            Map<String, String> response = new HashMap<>();
            response.put("jobId", jobId);
            response.put("message", "PartManager migration cancellation requested");
            
            return new ThedalResponse<>(ThedalSuccess.SUCCESS, response);
            
        } catch (ThedalException e) {
            throw e;
        } catch (Exception e) {
            log.error("Failed to cancel PartManager migration: {}", e.getMessage(), e);
            throw new ThedalException(ThedalError.OPERATION_FAILED, HttpStatus.INTERNAL_SERVER_ERROR);
        }
    }

    @GetMapping("/migration-stats")
    @Operation(summary = "Get PartManager migration statistics")
    public ThedalResponse<Map<String, Object>> getPartManagerMigrationStats() {
        
        // Validate account access
        Long accountId = requestDetails.getCurrentAccountId();
        if (accountId == null) {
            log.error("Account id not found, unauthorized access.");
            throw new ThedalException(ThedalError.ACCOUNT_ID_NOT_CREATED, HttpStatus.UNAUTHORIZED);
        }

        log.debug("Getting PartManager migration stats for accountId={}", accountId);

        try {
            // For now, get stats for all elections under this account
            // You might want to add electionId parameter if needed
            Map<String, Object> stats = partManagerMigrationService.getMigrationStats(accountId, null);
            
            return new ThedalResponse<>(ThedalSuccess.SUCCESS, stats);
            
        } catch (Exception e) {
            log.error("Failed to get PartManager migration stats: {}", e.getMessage(), e);
            throw new ThedalException(ThedalError.OPERATION_FAILED, HttpStatus.INTERNAL_SERVER_ERROR);
        }
    }
}
